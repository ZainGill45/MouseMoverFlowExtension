<UserControl x:Class="MouseMover.SettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <UserControl.Resources>
        <Style TargetType="TextBlock" x:Key="Label">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,12,0" />
        </Style>
        <Style TargetType="TextBlock" x:Key="Hint">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="10,0,0,0" />
            <Setter Property="Opacity" Value="0.6" />
            <Setter Property="FontSize" Value="11" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Width" Value="90" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="4,2" />
        </Style>
    </UserControl.Resources>

    <StackPanel Margin="16">
        <TextBlock Text="Mouse Mover" FontWeight="Bold" FontSize="15" />
        <TextBlock Text="Automatic randomized mouse movement. Toggle on/off from the search box with the &quot;mouse&quot; keyword; tune the behaviour here."
                   TextWrapping="Wrap" Opacity="0.7" Margin="0,4,0,14" />

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="36" />
                <RowDefinition Height="36" />
                <RowDefinition Height="36" />
                <RowDefinition Height="36" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource Label}" Text="Interval" />
            <TextBox    Grid.Row="0" Grid.Column="1" LostFocus="OnSave"
                        Text="{Binding IntervalMs, UpdateSourceTrigger=LostFocus}" />
            <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource Hint}"
                        Text="ms between moves (250 – 3,600,000)" />

            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource Label}" Text="Radius" />
            <TextBox    Grid.Row="1" Grid.Column="1" LostFocus="OnSave"
                        Text="{Binding Radius, UpdateSourceTrigger=LostFocus}" />
            <TextBlock Grid.Row="1" Grid.Column="2" Style="{StaticResource Hint}"
                        Text="px max distance per move (5 – 4000)" />

            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource Label}" Text="Glide" />
            <TextBox    Grid.Row="2" Grid.Column="1" LostFocus="OnSave"
                        Text="{Binding GlideMs, UpdateSourceTrigger=LostFocus}" />
            <TextBlock Grid.Row="2" Grid.Column="2" Style="{StaticResource Hint}"
                        Text="ms glide duration; 0 = instant jump (0 – 10,000)" />

            <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource Label}" Text="Step" />
            <TextBox    Grid.Row="3" Grid.Column="1" LostFocus="OnSave"
                        Text="{Binding StepMs, UpdateSourceTrigger=LostFocus}" />
            <TextBlock Grid.Row="3" Grid.Column="2" Style="{StaticResource Hint}"
                        Text="ms per glide step; lower = smoother (1 – 200)" />
        </Grid>

        <TextBlock Text="Changes save automatically and apply on the next move."
                   Opacity="0.6" FontSize="11" Margin="0,14,0,0" />
    </StackPanel>
</UserControl>
