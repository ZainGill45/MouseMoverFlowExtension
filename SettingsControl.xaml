<UserControl x:Class="MouseMover.SettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
      No Style is applied to any control on purpose. Flow Launcher's settings
      window (iNKORE.UI.WPF.Modern) supplies app-wide implicit styles for the
      standard TextBox type; applying our own Style would detach the inputs from
      that theme and make them look unstyled. So every control here uses plain
      inline attributes only: the TextBoxes keep the host's themed template, and
      the TextBlocks inherit the theme's foreground/font from their parent.
    -->
    <StackPanel Margin="16">
        <TextBlock Text="Mouse Mover" FontWeight="SemiBold" FontSize="15" />
        <TextBlock Text="Automatic randomized mouse movement. Toggle on/off from the search box with the &quot;mouse&quot; keyword; tune the behaviour here."
                   TextWrapping="Wrap" Opacity="0.7" Margin="0,4,0,16" />

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="42" />
                <RowDefinition Height="42" />
                <RowDefinition Height="42" />
                <RowDefinition Height="42" />
                <RowDefinition Height="42" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0" Text="Interval" />
            <TextBox    Grid.Row="0" Grid.Column="1" Width="110" VerticalAlignment="Center" LostFocus="OnSave"
                        Text="{Binding IntervalMs, UpdateSourceTrigger=LostFocus}" />
            <TextBlock Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Margin="10,0,0,0" Opacity="0.6" FontSize="11"
                        Text="ms between moves (250 – 3,600,000)" />

            <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0" Text="Radius" />
            <TextBox    Grid.Row="1" Grid.Column="1" Width="110" VerticalAlignment="Center" LostFocus="OnSave"
                        Text="{Binding Radius, UpdateSourceTrigger=LostFocus}" />
            <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Margin="10,0,0,0" Opacity="0.6" FontSize="11"
                        Text="px max distance per move (5 – 4000)" />

            <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0" Text="Glide" />
            <TextBox    Grid.Row="2" Grid.Column="1" Width="110" VerticalAlignment="Center" LostFocus="OnSave"
                        Text="{Binding GlideMs, UpdateSourceTrigger=LostFocus}" />
            <TextBlock Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" Margin="10,0,0,0" Opacity="0.6" FontSize="11"
                        Text="ms glide duration; 0 = instant jump (0 – 10,000)" />

            <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0" Text="Step" />
            <TextBox    Grid.Row="3" Grid.Column="1" Width="110" VerticalAlignment="Center" LostFocus="OnSave"
                        Text="{Binding StepMs, UpdateSourceTrigger=LostFocus}" />
            <TextBlock Grid.Row="3" Grid.Column="2" VerticalAlignment="Center" Margin="10,0,0,0" Opacity="0.6" FontSize="11"
                        Text="ms per glide step; lower = smoother (1 – 200)" />
            <CheckBox Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="0,8,12,0"
                      Content="Auto-disable on mouse input"
                      IsChecked="{Binding AutoDisableOnUserMouseInput, UpdateSourceTrigger=PropertyChanged}"
                      Click="OnSave" />
            <TextBlock Grid.Row="4" Grid.Column="2" VerticalAlignment="Center" Margin="10,8,0,0" Opacity="0.6" FontSize="11"
                        Text="stop the current run when you move, click, or scroll the mouse" />

            <CheckBox Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="0,0,12,0"
                      Content="Stay on current monitor"
                      IsChecked="{Binding RestrictMovementToCurrentMonitor, UpdateSourceTrigger=PropertyChanged}"
                      Click="OnSave" />
            <TextBlock Grid.Row="5" Grid.Column="2" VerticalAlignment="Center" Margin="10,0,0,0" Opacity="0.6" FontSize="11"
                        Text="keep random movement inside the monitor containing the cursor" />
        </Grid>

        <TextBlock Text="Changes save automatically and apply on the next move."
                   Opacity="0.6" FontSize="11" Margin="0,12,0,0" />
    </StackPanel>
</UserControl>
